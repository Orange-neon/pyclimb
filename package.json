{
  "name": "col",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "overrides": {
    "dompurify": "^3.4.11"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run validate:problems && tsc -b && vite build",
    "bank:new": "tsx scripts/create-bank-version.ts",
    "check": "npm run test && npm run verify:solutions && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false",
    "validate:problems": "tsx scripts/validate-problems.ts",
    "verify:solutions": "tsx scripts/verify-solutions.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "canvas-confetti": "^1.9.3",
    "firebase": "^12.6.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.552.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "pyodide": "0.25.0",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.14"
  }
}
